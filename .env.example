# Storage backend: mysql | file | memory (production must use mysql)
STORAGE_MODE=mysql
DATABASE_URL=

# HMAC secret for bearer tokens. REQUIRED in production — the server refuses to
# start with the default value when NODE_ENV=production. Use a long random string.
TOKEN_SECRET=

# Session lifetime in milliseconds (default 30 days). Expired sessions are rejected.
MAX_SESSION_AGE_MS=2592000000

# Comma-separated list of allowed CORS origins (e.g. your H5 domain). Empty = same-origin only.
CORS_ALLOWED_ORIGINS=

# Login brute-force protection.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MS=900000
LOGIN_ATTEMPT_WINDOW_MS=900000

# Maximum inbound request body size in bytes (default 1 MiB).
MAX_BODY_BYTES=1048576

# Uploaded avatar image storage.
UPLOAD_DIR=.data/uploads
MAX_IMAGE_UPLOAD_BYTES=524288
# Optional public origin used to generate absolute upload URLs.
PUBLIC_BASE_URL=

# Reminder scheduler.
LESSON_REMINDER_TEMPLATE_ID=pluT-ikzv-p5mBwXhcWIApzQqe4eyYQVyKlhha0h1b4
REMINDER_SCAN_INTERVAL_MS=60000

# WeChat mini-program credentials (required for openid exchange + reminder delivery).
WECHAT_APP_ID=
WECHAT_APP_SECRET=

NODE_OPTIONS=--use-system-ca
NODE_EXTRA_CA_CERTS=/app/cert/certificate.crt
# CloudBase Run mounts its platform root CA at /app/cert/certificate.crt.
# NODE_EXTRA_CA_CERTS makes Node trust that CA for outbound calls to
# api.weixin.qq.com; --use-system-ca keeps the OS trust store enabled too.
# Do not solve DEPTH_ZERO_SELF_SIGNED_CERT by disabling TLS checks.
# TLS verification for outbound WeChat API calls is ON by default. Only disable
# (WECHAT_TLS_REJECT_UNAUTHORIZED=false) for disposable local diagnostics; never
# leave it off in production.
# WECHAT_TLS_REJECT_UNAUTHORIZED=false
